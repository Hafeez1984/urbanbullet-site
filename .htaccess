<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # 1. Reverse proxy the empty root request to the Node.js server
    RewriteRule ^$ http://127.0.0.1:3081/ [P,L]
    
    # 2. Bypass rewrite for existing physical files (e.g. assets, static files)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # 3. Reverse proxy all other requests to the Node.js process running on port 3081
    RewriteRule ^(.*)$ http://127.0.0.1:3081/$1 [P,L]
</IfModule>
