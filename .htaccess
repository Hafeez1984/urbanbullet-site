# BEGIN passenger config
PassengerEnabled on
PassengerAppEnv production
PassengerNode /opt/alt/alt-nodejs22/root/usr/bin/node
PassengerAppRoot /home/u320819004/domains/urbanbullet.in/public_html
PassengerStartupFile server.js
PassengerAppType node
# END passenger config

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Send all requests to the Passenger handler (server.js)
    RewriteRule ^server\.js$ - [L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ server.js/$1 [QSA,L]
</IfModule>
